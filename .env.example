# Planning (LLM chat) endpoint (OpenAI-compatible)
PLANNING_BASE_URL=https://your-openai-compatible-host
PLANNING_API_KEY=
PLANNING_MODEL=claude-opus-4-7

# Image generation endpoint (OpenAI-compatible)
IMAGE_BASE_URL=https://your-openai-compatible-host
IMAGE_API_KEY=
IMAGE_MODEL=gpt-image-2

# Optional — Streamlit defaults to 1920x1080 (16:9, snapped to /16) if unset.
# `python -m editable_pptx` uses IMAGE_SIZE when set; if also unset, export still defaults to 16:9 (1920×1088).
# IMAGE_SIZE=1920x1080
#
# Optional export-only override (same WxH rules). Usually leave unset and use IMAGE_SIZE.
# EDITABLE_PPTX_CANVAS=1920x1088

# Optional
# PLANNING_MAX_TOKENS=12000

# --- Editable PPTX (`python -m editable_pptx`) — MinerU layout ---
MINERU_TOKEN=

# Optional MinerU overrides
# MINERU_API_BASE=https://mineru.net
# MINERU_MODEL_VERSION=vlm
# MINERU_POLL_TIMEOUT=600

# Background: edge (default) | whiteout | none — edge samples colors outside text boxes
# EDITABLE_PPTX_BG_MODE=edge

# Text box padding multiplier vs MinerU bbox (tighter = closer to 1.0)
# EDITABLE_PPTX_TEXT_PAD=1.005

# PowerPoint font names (must be installed on the machine opening the file). Optional title font.
# EDITABLE_PPTX_FONT_NAME=
# EDITABLE_PPTX_TITLE_FONT_NAME=

# OpenAI-compatible VLM for text style (bold, color, align) — analyze.md step (C).
# If BASE_URL / API_KEY omitted, falls back to PLANNING_BASE_URL / PLANNING_API_KEY.
# EDITABLE_PPTX_BASE_URL=
# EDITABLE_PPTX_API_KEY=
# EDITABLE_PPTX_STYLE_MODEL=

# Optional: same API, image inpaint model (not wired yet — reserved)
# EDITABLE_PPTX_INPAINT_MODEL=

# --- Reconstruction quality (Codia/NoteSlide-style) ---

# Native shape detection via the VLM (rounded cards, pills, dividers, arrows
# become editable DrawingML preset shapes). Requires VLM vars above. Default 1.
# EDITABLE_PPTX_SHAPE_DETECT=1

# Layout snap & alignment: round bboxes to a pixel grid then cluster shared
# edges/centers so columns line up. Default 1.
# EDITABLE_PPTX_LAYOUT_SNAP=1
# EDITABLE_PPTX_SNAP_GRID_PX=8
# EDITABLE_PPTX_SNAP_CLUSTER_PX=10

# Drop the full-page background bitmap; paint a flat fill from the VLM-inferred
# page background color instead. Best when shape detection is reliable. Default 0.
# EDITABLE_PPTX_BG_FLATTEN=0

# Crosscheck: render the produced PPTX back to PNGs via LibreOffice and ask the
# VLM to score similarity vs the source slides. Writes crosscheck_report.json.
# Default 0.
# EDITABLE_PPTX_CROSSCHECK=0
# EDITABLE_PPTX_SOFFICE=/Applications/LibreOffice.app/Contents/MacOS/soffice
